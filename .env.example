# Environment variables for Docker Compose
# Variables de entorno para Docker Compose
#
# IMPORTANTE: Copia este archivo a .env y cambia los valores
# IMPORTANT: Copy this file to .env and change the values
#
# cp .env.example .env

# PostgreSQL Configuration
POSTGRES_DB=your_postgres_db_password_here
POSTGRES_USER=your_postgres_user_password_here
POSTGRES_PASSWORD=your_postgres_password_here

# Redis Configuration (no password for development)
# REDIS_PASSWORD=your_redis_password_here

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
